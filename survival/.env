# These configs map to server.properties via the itzg/minecraft-server image

# Minecraft version
VERSION=1.21.11

# Name of the world folder
SERVER_WORLDNAME="Tobiasworld"

# Name shown in the server list
SERVER_NAME="Tobias"

# Message below the name
SERVER_MOTD="Bem-vindo ao servidor do Tobias!"

# Image showed at the servers list
SERVER_ICON="https://files.catbox.moe/c4tfq5.png"

# Core gameplay/policy
INIT_MEMORY=1G
MAX_MEMORY=6G
VIEW_DISTANCE=10
SIMULATION_DISTANCE=8
ALLOW_FLIGHT=true
SPAWN_MONSTERS=false
DIFFICULTY="normal"            # peaceful|easy|normal|hard
ENABLE_COMMAND_BLOCK=false
ONLINE_MODE=false               # false: allows pirate users
ENABLE_STATUS="true"           # allow status queries (server list pings)
OPS=
ENABLE_WHITELIST=false
# WHITELIST=
RCON_PASSWORD=tobias
